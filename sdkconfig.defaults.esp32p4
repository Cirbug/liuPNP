# ================================================================
# AI-PNP ESP32-P4 默认配置
# ================================================================

# ---- 板载 LED ----
CONFIG_BLINK_LED_STRIP=y
CONFIG_BLINK_GPIO=44

# ---- WiFi (使用前修改 SSID/PASSWORD) ----
CONFIG_WIFI_SSID="YOUR_WIFI_SSID"
CONFIG_WIFI_PASSWORD="YOUR_WIFI_PASSWORD"

# ---- PSRAM (摄像头缓冲必需) ----
CONFIG_SPIRAM=y
CONFIG_SPIRAM_USE_CAPS_ALLOC=y
CONFIG_SPIRAM_ALLOW_BSS_SEG_EXTERNAL_MEMORY=y

# ---- 摄像头 (esp_camera 组件) ----
CONFIG_CAMERA_ENABLE=y
CONFIG_CAMERA_MODEL_ESP32P4=y
CONFIG_CAMERA_PIN_XCLK=15
CONFIG_CAMERA_PIN_SIOD=10
CONFIG_CAMERA_PIN_SIOC=11
CONFIG_CAMERA_PIN_PWDN=-1
CONFIG_CAMERA_PIN_RESET=-1

# ---- FATFS (TF 卡读取 CSV) ----
CONFIG_FATFS_LFN_HEAP=y
CONFIG_FATFS_MAX_LFN=128
